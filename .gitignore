# Environment
.venv/
venv/
env/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Amazo runtime files
amazo.log
my-core/my-config.yaml
my-core/my-config.yaml.gpg
