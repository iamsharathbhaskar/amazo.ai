# Environment
.venv/
venv/
env/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
.Rhistory

# OS
.DS_Store
Thumbs.db

# Amazo runtime files
*.log
my-core/my-config.yaml
my-core/my-config.yaml.gpg
my-core/my-heartbeat.txt

# User directories — keep structure via .gitkeep, ignore contents
my-journals/*
!my-journals/.gitkeep
my-archive/*
!my-archive/.gitkeep
my-contacts/*
!my-contacts/.gitkeep
my-workshop/*
!my-workshop/.gitkeep
my-post-its/*
!my-post-its/.gitkeep

# Projects — keep the rabbit-holes structure, ignore contents
my-projects/*
!my-projects/rabbit-holes/
my-projects/rabbit-holes/*
!my-projects/rabbit-holes/.gitkeep

# Distribution archives
*.tar.gz
*.zip

# Plan and design docs (contain personal context)
amazo-v2-full-recap.md
*recap*.md
*.plan.md

# Signal status
.signal-status

# Preferred provider (runtime file)
my-core/preferred-provider.txt

# File protection backups (runtime)
my-core/.backups/
